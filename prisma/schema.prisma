generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  activo
  bloqueado
  eliminado
}

enum FacebookTokenStatus {
  valido
  por_vencer
  expirado
  requiere_reconexion
  error_permiso
  error_desconocido
}

enum BatchStatus {
  pending_upload
  pendiente_confirmacion
  confirmado
  generando
  generado_parcial
  completado
  fallido
  cancelado
  abandonado
}

enum PhotoStatus {
  subida
  analizando
  validada
  optimizada
  clasificada
  descartada
  usada
  eliminada
}

enum VariantStatus {
  pendiente
  generando
  generada
  fallida
  aprobada
  rechazada
  programada
  publicada
  eliminada
}

enum ScheduledPostStatus {
  pendiente
  programada
  publicacion_en_proceso
  publicada
  estado_incierto
  fallida
  pausada_por_token
  cancelada
}

enum LearningEventType {
  variante_generada
  variante_aprobada
  variante_rechazada
  estilo_cambiado_por_usuario
  caption_editado_por_usuario
  post_publicado
  post_fallido
  metricas_recolectadas
  accion_aprobada_en_swipe_autonomia
  accion_rechazada_en_swipe_autonomia
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String?
  status       UserStatus @default(activo)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  sessions     Session[]
  businesses   Business[]
  auditLogs    AuditLog[]
  metaIntegration MetaIntegration?
}

model Session {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  refreshTokenHash String
  deviceInfo     String?
  expiresAt      DateTime
  revokedAt      DateTime?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MetaIntegration {
  id                   String              @id @default(uuid()) @db.Uuid
  userId               String              @unique @db.Uuid
  accessTokenEncrypted  String?
  tokenStatus          FacebookTokenStatus  @default(expirado)
  lastValidatedAt      DateTime?
  expiresAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages                FacebookPageConnection[]
}

model FacebookPageConnection {
  id                   String              @id @default(uuid()) @db.Uuid
  metaIntegrationId    String              @db.Uuid
  pageId               String              @unique
  pageName             String
  coverPhotoUrl        String?
  pageAccessTokenEncrypted String?
  isSelected            Boolean             @default(false)
  tokenStatus          FacebookTokenStatus  @default(expirado)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  metaIntegration      MetaIntegration     @relation(fields: [metaIntegrationId], references: [id], onDelete: Cascade)

  @@index([metaIntegrationId])
}

model Business {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @db.Uuid
  name            String
  industry        String
  facebookPageId  String      @unique
  tokenStatus     FacebookTokenStatus @default(expirado)
  timezone        String
  metadata        Json?
  autonomySettings Json
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageConnection   FacebookPageConnection? @relation(fields: [facebookPageId], references: [pageId])
  batches         Batch[]
  scheduledPosts  ScheduledPost[]
  auditLogs       AuditLog[]
  events          BusinessLearningEvent[]
}

model Batch {
  id                String      @id @default(uuid()) @db.Uuid
  businessId        String      @db.Uuid
  status            BatchStatus
  photosCount       Int         @default(0)
  variantsCount     Int         @default(0)
  estimatedCostUsd  Float?
  confirmedCostUsd  Float?
  lastActivityAt    DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  business          Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  originalPhotos    OriginalPhoto[]
  generatedVariants GeneratedVariant[]
  scheduledPosts    ScheduledPost[]

  @@index([businessId])
}

model OriginalPhoto {
  id                String      @id @default(uuid()) @db.Uuid
  batchId           String      @db.Uuid
  storageProvider   String
  fileUrlInternal   String
  visionAnalysis    Json?
  assignedStyle     Json?
  editingPrompt     String?
  visionAnalyzedAt  DateTime?
  status            PhotoStatus
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  batch             Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  generatedVariants GeneratedVariant[]

  @@index([batchId])
}

model GeneratedVariant {
  id                String      @id @default(uuid()) @db.Uuid
  batchId           String      @db.Uuid
  originalPhotoId   String      @db.Uuid
  styleId           String
  generationPlan     Json
  promptUsed        String
  imageUrl          String?
  caption           String?
  costs             Json?
  status            VariantStatus
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  batch             Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  originalPhoto     OriginalPhoto @relation(fields: [originalPhotoId], references: [id], onDelete: Cascade)
  scheduledPosts    ScheduledPost[]

  @@index([batchId])
  @@index([originalPhotoId])
}

model ScheduledPost {
  id                String      @id @default(uuid()) @db.Uuid
  variantId         String      @db.Uuid
  businessId        String      @db.Uuid
  batchId           String      @db.Uuid
  scheduledFor      DateTime
  facebookPostId    String?
  status            ScheduledPostStatus
  retryCount        Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  variant           GeneratedVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  business          Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  batch             Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  postPerformance   PostPerformance?

  @@index([businessId])
  @@index([batchId])
}

model PostPerformance {
  id                String      @id @default(uuid()) @db.Uuid
  scheduledPostId   String      @unique @db.Uuid
  metrics           Json
  score             Float
  collectionWindow  Json
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  scheduledPost     ScheduledPost @relation(fields: [scheduledPostId], references: [id], onDelete: Cascade)
}

model Style {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String
  promptTemplate        String
  recommendedIndustries String[]
  intensity             String
  aiDisclosureRequired  Boolean
  restrictions          String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  negocioId    String?  @db.Uuid
  userId       String?  @db.Uuid
  action       String
  entityType   String
  oldValue     Json?
  newValue     Json?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  business     Business? @relation(fields: [negocioId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([negocioId])
}

model BusinessLearningEvent {
  id            String              @id @default(uuid()) @db.Uuid
  negocioId     String              @db.Uuid
  type          LearningEventType
  occurredAt    DateTime
  styleId       String?
  styleName     String?
  photoType     String?
  captionPattern String?
  scheduledFor  DateTime?
  score         Float?
  costUsd       Float?
  provider      String?
  model         String?
  actionType    String?
  createdAt     DateTime            @default(now())

  business      Business            @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@index([negocioId])
  @@index([type])
}
