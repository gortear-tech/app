{
  "name": "@fbmaniaco/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "App.tsx",
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo/metro-runtime": "~4.0.1",
    "@fbmaniaco/shared": "workspace:*",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.8",
    "expo-image-picker": "~16.0.0",
    "expo-secure-store": "~14.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-web": "~0.19.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^15.1.3",
    "@types/react": "^18.3.12",
    "babel-preset-expo": "~12.0.0"
  },
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "pnpm dlx eas-cli build -p android --profile preview",
    "build:android:production": "pnpm dlx eas-cli build -p android --profile production",
    "build:ios": "pnpm dlx eas-cli build -p ios --profile preview",
    "build:ios:production": "pnpm dlx eas-cli build -p ios --profile production",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
