{
  "cli": {
    "version": ">= 15.0.0"
  },
  "build": {
    "development": {
      "env": {
        "APP_VARIANT": "development"
      },
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "env": {
        "APP_VARIANT": "preview"
      },
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "APP_VARIANT": "production",
        "API_URL": "https://fbmaniaco-api.onrender.com"
      },
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
