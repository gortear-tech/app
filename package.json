{
  "name": "fbmaniaco-v1",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "node scripts/run-pnpm.mjs -r build",
    "typecheck": "node scripts/run-pnpm.mjs -r typecheck",
    "lint": "node scripts/run-pnpm.mjs -r lint",
    "test": "node scripts/run-pnpm.mjs -r test",
    "format": "prettier --check .",
    "verify:pilot": "node scripts/pilot-readiness.mjs",
    "smoke:deploy": "node scripts/deploy-smoke.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:migrate:status": "node scripts/db-migrate.mjs --status",
    "db:migrate:check": "node scripts/db-migrate.mjs --check",
    "dev:api": "node scripts/run-pnpm.mjs --filter @fbmaniaco/api dev",
    "dev:worker": "node scripts/run-pnpm.mjs --filter @fbmaniaco/worker dev",
    "dev:mobile": "node scripts/run-pnpm.mjs --filter @fbmaniaco/mobile start",
    "smoke": "node scripts/run-pnpm.mjs --filter @fbmaniaco/api smoke && node scripts/run-pnpm.mjs --filter @fbmaniaco/worker smoke"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
