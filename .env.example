# Shared
APP_ENV=development
LOG_LEVEL=info
APP_RELEASE=local-dev
DATA_STORE_MODE=local
ALLOW_LOCAL_DATASTORE=true

# API server config
HOST=0.0.0.0
PORT=4000
CORS_ORIGIN=*
MAX_UPLOAD_BODY_MB=8
LOCAL_AUTH_ENABLED=true
LOCAL_DB_PATH=apps/api/data/local-db.json

# Supabase server-side config. Never put service role values in mobile env.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=
DATABASE_URL=
SUPABASE_MEDIA_BUCKET=fbmaniaco-media

# Meta server-only OAuth config
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/auth/meta/callback
META_LOGIN_CONFIGURATION_ID=
META_GRAPH_API_VERSION=v23.0
META_REQUIRED_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts
# Development only. Paste a short-lived user token here to import real test pages server-side.
META_TEST_USER_ACCESS_TOKEN=

# OpenAI server-only config. Never expose this to mobile.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_VISION_MODEL=gpt-5.5
OPENAI_CAPTION_MODEL=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_VISION_TIMEOUT_MS=30000
OPENAI_IMAGE_TIMEOUT_MS=30000

# Operational safety switches. Server-side only.
FEATURE_META_PUBLISHING=true
FEATURE_OPENAI_VISION=true
FEATURE_OPENAI_IMAGE_GENERATION=true
WORKER_POLL_INTERVAL_MS=5000
SENTRY_DSN=

# Mobile public config only
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=http://localhost:4000
