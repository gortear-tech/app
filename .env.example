# API
HOST=0.0.0.0
PORT=4101
NODE_ENV=development
SESSION_SECRET=replace_me
PASSWORD_PEPPER=replace_me
DATABASE_URL=postgresql://user:password@localhost:5432/fbmaniaco
REDIS_URL=redis://127.0.0.1:6380
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_CAPTION_MODEL=gpt-5.4-mini
VISION_ANALYSIS_TIMEOUT_MS=30000
OPENAI_API_KEY=replace_me
SUPABASE_URL=replace_me
SUPABASE_SERVICE_ROLE=replace_me
META_BOOTSTRAP_TOKEN=replace_me
META_APP_ID=replace_me
META_APP_SECRET=replace_me
META_REDIRECT_URI=replace_me
META_DEVICE_LOGIN_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts
STATE_FILE_PATH=apps/api/data/fbmaniaco-state.json

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:4101
EXPO_PUBLIC_META_BOOTSTRAP_TOKEN=replace_me
# Production builds should set API_URL and leave the bootstrap token unset.
API_URL=replace_me
EXPO_PUBLIC_SUPABASE_URL=replace_me
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace_me
EXPO_PUBLIC_META_APP_ID=replace_me
EXPO_PUBLIC_META_REDIRECT_URI=replace_me

# Worker
WORKER_MODE=idle
PUBLISH_BATCH_SIZE=20
ABANDONED_BATCH_SIZE=50
